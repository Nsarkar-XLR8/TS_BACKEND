{
  "name": "ts_boiler_plate",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start:dev": "tsx watch src/server.ts",
    "dev": "npx kill-port 5001 && tsx watch --clear-screen=false src/server.ts",
    "dev:stack": "docker compose up --build api worker-bullmq worker-kafka worker-rabbitmq mongo redis rabbitmq kafka loki promtail grafana",
    "worker:bullmq": "tsx src/workers/worker-bullmq.ts",
    "worker:kafka": "tsx src/workers/worker-kafka-consumer.ts",
    "worker:rabbitmq": "tsx src/workers/worker-rabbitmq-consumer.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:api": "spectral lint openapi.json",
    "build": "npm run typecheck && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration:containers": "vitest run tests/integration/containerized.test.ts",
    "check:contracts": "npm run export:openapi && npm run lint:api",
    "check:security": "npm run audit:ci",
    "check:all": "npm run typecheck && npm run lint && npm run test && npm run check:contracts && npm run check:security",
    "clean": "rimraf dist",
    "ci": "npm run audit:ci && npm run typecheck && npm run lint && npm run test",
    "audit:ci": "npm audit --audit-level=high",
    "migrate:up": "npx migrate-mongo up -f migrate-mongo-config.ts",
    "migrate:down": "npx migrate-mongo down -f migrate-mongo-config.ts",
    "migrate:create": "npx migrate-mongo create -f migrate-mongo-config.ts",
    "migrate:status": "npx migrate-mongo status -f migrate-mongo-config.ts",
    "seed": "tsx src/database/seeds/index.ts",
    "export:openapi": "tsx scripts/export-openapi.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-errors": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "migrate-mongo": "^14.0.7",
    "mongoose": "^9.2.1",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "mysql2": "^3.19.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/connect-timeout": "^1.9.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/migrate-mongo": "^10.0.6",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
