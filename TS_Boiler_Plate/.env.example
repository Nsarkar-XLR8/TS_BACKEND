# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
# Supported types: mongodb, postgres, mysql
DB_TYPE=mongodb

# Get your MongoDB connection string from: https://cloud.mongodb.com/
MONGODB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/your_database_name

# Postgres Connection String
# POSTGRES_URL=postgresql://username:password@localhost:5432/your_database_name

# MySQL Connection String
# MYSQL_URL=mysql://username:password@localhost:3306/your_database_name

# JWT Configuration
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_min_32_characters
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary Configuration (for file uploads)
# Sign up at: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (for sending emails)
# For Gmail: Use App Password from https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password
ADMIN_EMAIL=admin@example.com

# OpenTelemetry Configuration (Optional - for observability)
OTEL_SERVICE_NAME=ts-boilerplate-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_TRACES_EXPORTER=otlp

# Stripe Configuration (Optional - for payments)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_ADMIN_SECRET=whsec_your_webhook_secret

# Security Configuration (Optional - for encryption)
# AES_KEY=your_32_character_aes_key
# AES_IV=your_16_character_initialization_vector

# Redis Configuration (Optional — app works without it)
# REDIS_URL=redis://localhost:6379

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Proxy Configuration (set to true if behind a reverse proxy like Nginx)
TRUST_PROXY=false

# ── Infrastructure (Optional) ──
# RabbitMQ Connection URL
# RABBITMQ_URL=amqp://localhost:5672

# Kafka Brokers (comma-separated if multiple)
# KAFKA_BROKERS=localhost:9092

# Grafana Loki URL for distributed logging
# LOKI_URL=http://localhost:3100

# ── OAuth Identities (Optional) ──
# Google OAuth 2.0
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# Frontend URLs (Optional)
# RESET_PASSWORD_URL=http://localhost:3000/reset-password
# FRONT_END_URL=http://localhost:3000
